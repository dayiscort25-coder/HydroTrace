# HydroTrace Environment Variables
# Copy this file to .env and populate with your actual Supabase credentials.

# Supabase Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon/Public Key (safe to use on client-side)
SUPABASE_ANON_KEY=your-anon-key-here

# (Optional) Supabase Service Role Key - NEVER expose on client-side
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
